  fishFactText: {fileID: 667541925}
  resultText: {fileID: 1985200344}
  targets:
  - fishID: AngleFish
    fishName: Angle Fish
    fishImage: {fileID: 21300000, guid: dc5c78de5b8fe4cf79cb52c82dafff52, type: 3}
    fishFact: Angelfish include over 80 marine species and three freshwater varieties.
      Famous for their thin, disk-like shapes and wing-like fins, they range from
      3 to 24 inches long. They are highly adaptable, with a diverse omnivorous diet,
      and can live anywhere from 7 to 20+ years depending on the species
  - fishID: ClownFish
    fishName: Clown Fish
    fishImage: {fileID: 21300000, guid: 69b6ffa4bc27846daabe8a1b8f5eccf1, type: 3}
    fishFact: Clownfish are vibrant, omnivorous marine fish native to the tropical
      waters of the Indian and Pacific Oceans. Famous for their symbiotic partnership
      with venomous sea anemones, they famously possess a protective slime coat that
      renders them immune to the anemone's stings
  - fishID: SeaHorse
    fishName: Seahorse
    fishImage: {fileID: 21300000, guid: 071f1dbc072d54ad281237803afab1ec, type: 3}
    fishFact: Dottybacks are small, vibrantly colored, and territorial saltwater
      fish native to Indo-Pacific coral reefs. Belonging to the family Pseudochromidae,
      they are popular among marine aquarists for their hardiness and bright hues,
      but they are known for their bold, semi-aggressive personalities. They roam
      around in groups.
  hudController: {fileID: 511501192}
